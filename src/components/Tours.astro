---
import SprayStroke from './SprayStroke.astro';
import TourCard from './TourCard.astro';
import { TOURS } from '../data/tours';
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

<section id="tour" class="bg-paper text-ink">
  <div class="mx-auto max-w-6xl px-5 pb-20 md:px-10 md:pb-28">
    <h2 class="font-display text-4xl font-bold md:text-5xl" style="--stroke: var(--color-giorno)">
      {dict.tours.heading}
      <SprayStroke />
    </h2>
    <p class="eyebrow mt-3 text-ink/55">{dict.tours.sub}</p>

    <div class="mt-10 grid gap-6 md:grid-cols-2 md:gap-8">
      {TOURS.map((tour) => <TourCard tour={tour} locale={locale} />)}
    </div>
  </div>
</section>
