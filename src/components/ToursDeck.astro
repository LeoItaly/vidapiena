---
import SprayStroke from './SprayStroke.astro';
import TourCard from './TourCard.astro';
import { TOURS } from '../data/tours';
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
const total = String(TOURS.length).padStart(2, '0');
---

{/*
  The catalogue, second thing on the page. One markup tree, two presentations —
  the same trick the descent zones use: default CSS renders a plain grid (no-JS,
  reduced motion, Save-Data, 2G), and `.motion-ok` turns those exact nodes into a
  pinned depth corridor where one tour at a time flies toward the reader.
*/}
<section id="tour" class="tours-deck bg-ink text-paper" data-tours-deck>
  <div class="deck-sticky">
    <div class="deck-head mx-auto w-full max-w-6xl px-5 pt-14 md:px-10 md:pt-16">
      <h2 class="font-display text-3xl font-bold md:text-4xl" style="--stroke: var(--color-giorno)">
        {dict.tours.heading}
        <SprayStroke />
      </h2>
      <p class="eyebrow mt-3 text-paper/60">{dict.tours.sub}</p>
    </div>

    <div class="deck-space mx-auto w-full max-w-6xl px-5 md:px-10">
      {
        TOURS.map((tour, i) => (
          <div class="deck-card" data-deck-card={i}>
            <TourCard tour={tour} locale={locale} />
          </div>
        ))
      }
    </div>

    <div class="deck-progress" aria-hidden="true">
      <span class="deck-counter tabular-nums" data-deck-counter>01 / {total}</span>
      <span class="deck-ticks">
        {/* First tick pre-lit so the opening frame is right before the scrub's
            first update fires. */}
        {TOURS.map((_, i) => <span class={`deck-tick${i === 0 ? ' is-active' : ''}`} data-deck-tick />)}
      </span>
    </div>
  </div>
</section>

<style>
  /* ---- Static path (default) — a readable grid, nothing depends on JS ---- */
  .deck-space {
    display: grid;
    gap: 1.5rem;
    margin-top: 2.5rem;
    padding-bottom: 5rem;
  }
  @media (min-width: 768px) {
    .deck-space {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
  .deck-progress {
    display: none;
  }
  /* TourCard is built for the light panel it used to live on; on ink it needs
     an opaque surface instead of `bg-white/60`. */
  .deck-card :global(article) {
    background: var(--color-paper);
  }

  /* ---- Motion path — pinned depth corridor -------------------------------
     Scroll length lives on the section; the viewport-height child sticks to the
     top while `tours-deck.ts` scrubs the cards through it on the z axis. */
  :global(.motion-ok) .tours-deck {
    height: 440svh;
  }
  @media (min-width: 768px) {
    :global(.motion-ok) .tours-deck {
      height: 480svh;
    }
  }

  :global(.motion-ok) .deck-sticky {
    position: sticky;
    top: 0;
    display: flex;
    height: 100svh;
    flex-direction: column;
    /* Clips cards flying past the camera. Safe on the sticky element itself —
       it is overflow on an *ancestor* that would kill stickiness. */
    overflow: hidden;
  }
  :global(.motion-ok) .deck-head {
    padding-top: 2.5rem;
  }
  @media (min-width: 768px) {
    :global(.motion-ok) .deck-head {
      padding-top: 3.5rem;
    }
  }

  :global(.motion-ok) .deck-space {
    position: relative;
    display: block;
    flex: 1;
    margin-top: 0;
    padding-bottom: 0;
    perspective: 900px;
    perspective-origin: 50% 45%;
    /* Keeps cards sorted by real z depth instead of DOM order, so an exiting
       card passes in *front* of the one rising behind it. Never put
       `overflow` here — it would force `transform-style: flat`. */
    transform-style: preserve-3d;
  }
  @media (min-width: 768px) {
    :global(.motion-ok) .deck-space {
      perspective: 1200px;
    }
  }

  :global(.motion-ok) .deck-card {
    position: absolute;
    /* inset + auto margins centre the card without a transform of its own —
       GSAP owns `transform` outright. */
    inset: 0;
    margin: auto;
    width: min(34rem, 92vw);
    height: fit-content;
    will-change: transform, opacity;
  }
  /* Pre-init pose, mirroring `.backdrop-layer`: between the `.motion-ok` flip
     and the first frame, only the front card may paint. */
  :global(.motion-ok) .deck-card:not(:first-child) {
    opacity: 0;
    visibility: hidden;
  }
  :global(.motion-ok) .deck-card :global(article) {
    box-shadow: 0 30px 60px -25px rgb(0 0 0 / 0.65);
  }
  /* The card must fit a phone viewport whole — the photo yields first. */
  :global(.motion-ok) .deck-card :global(img) {
    max-height: 32svh;
  }

  :global(.motion-ok) .deck-progress {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    padding-bottom: 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    color: color-mix(in srgb, var(--color-paper) 70%, transparent);
  }
  .deck-ticks {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .deck-tick {
    display: block;
    height: 2px;
    width: 1.4rem;
    background: color-mix(in srgb, var(--color-paper) 30%, transparent);
    transition:
      width 0.3s ease,
      background-color 0.3s ease;
  }
  .deck-tick.is-active {
    width: 2.4rem;
    background: var(--color-ambra);
  }
</style>
