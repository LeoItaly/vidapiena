---
/**
 * Visible mono breadcrumb + its BreadcrumbList JSON-LD (body placement is
 * valid for structured data). The last item is the current page: no link.
 */
import JsonLdScript from './JsonLdScript.astro';
import { t, absoluteUrl, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  /** hrefs are already-resolved site paths (base included); last item has none. */
  items: { label: string; href?: string }[];
}
const { locale, items } = Astro.props;
const dict = t(locale);

const graph = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.label,
    ...(item.href && { item: absoluteUrl(item.href) }),
  })),
};
---

<nav aria-label={dict.a11y.breadcrumbLabel}>
  <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs tracking-[0.16em] uppercase">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-2">
          {i > 0 && (
            <span class="opacity-40" aria-hidden="true">
              /
            </span>
          )}
          {item.href ? (
            <a href={item.href} class="link-sweep opacity-70 transition-opacity hover:opacity-100">
              {item.label}
            </a>
          ) : (
            <span aria-current="page" class="text-ouro">
              {item.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<JsonLdScript graph={graph} />
