---
import video16Url from '../assets/video/logo-reveal-16x9.mp4?url';
import video9Url from '../assets/video/logo-reveal-9x16.mp4?url';
import OtaLogo from './OtaLogo.astro';
import { PLATFORMS } from '../lib/platforms';
import { getHeroPosters, POSTER_MEDIA } from '../lib/posters';
import { t, pagePath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);

// Shared transforms with BaseHead's preloads — one poster download per viewport.
const posters = await getHeroPosters();

/*
 * Mini trust row — same marks and trademark rules as TrustBadges (official
 * variants, no recoloring, light background), scaled down and set on light
 * chips so they stay legible over the dark hero. Low priority: nothing here
 * may compete with the poster for the LCP.
 */
const CHIP_SIZES: Record<string, string> = {
  viator: 'h-3',
  getyourguide: 'h-3.5',
  airbnb: 'h-3.5',
  civitatis: 'h-2.5',
};
const badges = PLATFORMS.map((p) => ({ ...p, h: CHIP_SIZES[p.key] }));
---

{/* `data-hero` (not <header>) — the site header is the fixed Nav now; the
    corner furniture and the nav's scrolled-state trigger both key off this. */}
<section data-hero class="relative h-svh overflow-hidden">
  <!-- Poster = the LCP element. The reveal video layers on top later (M3 script),
       and its final frame pixel-matches this poster by design of the asset. -->
  <picture>
    <source media={POSTER_MEDIA.portrait} srcset={posters.portrait.src} />
    <img
      src={posters.landscape.src}
      alt={dict.meta.ogAlt}
      class="absolute inset-0 h-full w-full object-cover"
      fetchpriority="high"
      decoding="async"
    />
  </picture>
  <video
    class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500"
    muted
    playsinline
    preload="none"
    aria-label={dict.a11y.heroVideoLabel}
    data-hero-video
    data-src-landscape={video16Url}
    data-src-portrait={video9Url}
  ></video>

  <!-- Legibility scrim -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-ink via-ink/40 to-ink/45"
    aria-hidden="true"
  >
  </div>

  <!-- Headline block — says what this is (guide, city, language) before anything moves -->
  <div class="absolute inset-x-0 bottom-0 z-10 px-5 pb-20 md:px-10 md:pb-24">
    <p class="eyebrow text-ouro" data-scramble>{dict.hero.kicker}</p>
    <h1
      class="font-display mt-3 max-w-[16ch] text-[clamp(2.1rem,7vw,5.5rem)] leading-[1.02] font-bold text-balance"
    >
      <span class="block">{dict.hero.h1[0]}</span>
      <span class="block text-ouro">{dict.hero.h1[1]}</span>
    </h1>
    <p class="mt-4 max-w-xl text-[0.95rem] leading-relaxed text-paper/85 md:text-lg">
      {dict.hero.sub}
    </p>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <a href="#tour" class="btn btn-primary">{dict.hero.ctaTours}</a>
      <a href={pagePath(locale, 'contatti/')} class="btn btn-ghost">{dict.nav.contact}</a>
    </div>

    <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-2">
      <span class="eyebrow text-paper/55">{dict.hero.otaLabel}</span>
      <ul class="flex flex-wrap items-center gap-2">
        {
          badges.map((b) => (
            <li class="flex items-center rounded-full bg-paper/90 px-2.5 py-1">
              {/* Inline SVG / intrinsic-size PNG — either way the chip reserves
                  its width before paint; these sit above the fold, and a reflow
                  here would shift the whole bottom-anchored headline block. */}
              <OtaLogo platform={b.key} name={b.name} class={b.h} loading="eager" />
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="absolute inset-x-0 bottom-0 z-10 px-5 pb-5 md:px-10 md:pb-7" aria-hidden="true">
    <p class="scroll-cue font-mono text-xs tracking-[0.2em] uppercase opacity-80">
      ↓ {dict.hero.scrollCue}
    </p>
  </div>
</section>
