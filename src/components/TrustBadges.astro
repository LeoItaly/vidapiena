---
import OtaLogo from './OtaLogo.astro';
import { PLATFORMS } from '../lib/platforms';
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);

/*
 * Trademark rules (visual-references/platform-logos/README.md): official variants
 * only, no recoloring, equal optical height, light neutral background. The
 * marquee only translates the row — no filters are ever applied to these marks.
 * Deliberately UNLINKED (OTA-LINKS.md rule): this is the global "Vidapiena is
 * on…" row — per-tour deep links belong on the cards and tour pages, and a
 * global badge pointing at one arbitrary tour's listing would mislead.
 */
const SIZES: Record<string, string> = {
  viator: 'h-6 md:h-7',
  getyourguide: 'h-7 md:h-8',
  airbnb: 'h-7 md:h-8',
  civitatis: 'h-5 md:h-6',
};
const badges = PLATFORMS.map((p) => ({ key: p.key, name: p.name, h: SIZES[p.key] }));
---

{/* The band is ink like its neighbours; the trademark "light neutral
    background" now lives on a floating paper panel — two hard seams
    (FinalCta→here, here→Footer) become none. */}
<section class="bg-ink text-paper">
  <div class="mx-auto max-w-5xl px-5 py-16 md:px-10 md:py-20">
    <div class="badge-panel rounded-xl bg-paper px-6 py-10 text-ink md:px-10">
      <p class="eyebrow text-center text-ink/55" data-scramble>{dict.badges.heading}</p>

    {/* Default: the centred row it has always been. With motion: the same list
        becomes a slow, endless drift that quickens as you scroll past. Four
        server-rendered copies (the row is short) keep the CSS -50% base loop
        seamless before the JS engine adopts it; duplicates are display:none on
        the static path. */}
    <div class="badge-row mt-8" data-marquee-row data-dir="-1" data-speed="38" style="--mq-dur: 90s">
      <div class="badge-track" data-marquee-track>
        {
          [0, 1, 2, 3].map((copy) => (
            <ul
              class:list={['badge-seq', copy > 0 && 'mq-dupe']}
              data-marquee-seq={copy === 0 ? true : undefined}
              aria-hidden={copy > 0 ? 'true' : undefined}
            >
              {badges.map((b) => (
                <li class="flex items-center">
                  <OtaLogo platform={b.key} name={b.name} class={b.h} />
                </li>
              ))}
            </ul>
          ))
        }
      </div>
    </div>
    </div>
  </div>
</section>

<style>
  .badge-panel {
    box-shadow: 0 24px 80px -32px rgb(0 0 0 / 0.8);
  }
  /* ---- Static path (default) — the centred, wrapping row ----------------- */
  .badge-seq {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.5rem 3rem;
  }

  /* ---- Motion path — endless drift -------------------------------------- */
  :global(.motion-ok) .badge-row {
    overflow: hidden;
    /* Edges dissolve instead of clipping a logo in half. */
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 8%,
      #000 92%,
      transparent 100%
    );
  }
  :global(.motion-ok) .badge-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }
  :global(.motion-ok) .badge-seq {
    flex-wrap: nowrap;
    justify-content: flex-start;
    /* Trailing gap inside the sequence — its measured width is the exact wrap
       distance, so the loop has no seam. */
    gap: 3rem;
    padding-right: 3rem;
  }
</style>
