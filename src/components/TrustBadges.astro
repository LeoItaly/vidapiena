---
import viatorLogo from '../assets/logos/viator.png';
import airbnbLogo from '../assets/logos/airbnb.svg';
import gygLogo from '../assets/logos/getyourguide.svg';
import civitatisLogo from '../assets/logos/civitatis.svg';
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);

/*
 * Trademark rules (visual-references/platform-logos/README.md): official variants
 * only, no recoloring, equal optical height, light neutral background.
 * TODO(Leo): wrap each badge in a deep link once live listing URLs are confirmed.
 */
const badges = [
  { name: 'Viator', logo: viatorLogo, h: 'h-6 md:h-7' },
  { name: 'GetYourGuide', logo: gygLogo, h: 'h-7 md:h-8' },
  { name: 'Airbnb', logo: airbnbLogo, h: 'h-7 md:h-8' },
  { name: 'Civitatis', logo: civitatisLogo, h: 'h-5 md:h-6' },
];
---

<section class="bg-paper text-ink">
  <div class="mx-auto max-w-5xl px-5 py-14 md:px-10 md:py-16">
    <p class="eyebrow text-center text-ink/55">{dict.badges.heading}</p>
    <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-12 gap-y-6">
      {
        badges.map((b) => (
          <li class="flex items-center">
            <img
              src={b.logo.src}
              alt={b.name}
              class={`w-auto ${b.h}`}
              loading="lazy"
              decoding="async"
            />
          </li>
        ))
      }
    </ul>
  </div>
</section>
