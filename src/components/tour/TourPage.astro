---
/**
 * The tour detail template — one component, four tours, two locales.
 * Everything variable comes from tours.ts (facts) + the tourPage dictionary
 * (copy), so the four pages can never drift structurally.
 */
import { Picture, getImage } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Footer from '../Footer.astro';
import Breadcrumbs from '../Breadcrumbs.astro';
import JsonLdScript from '../JsonLdScript.astro';
import TourGallery from './TourGallery.astro';
import TourBooking from './TourBooking.astro';
import { getPhoto } from '../../lib/photos';
import { SITE } from '../../data/site';
import { TOURS, type Tour } from '../../data/tours';
import { t, pagePath, localeHref, absoluteUrl, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
  tour: Tour;
}
const { locale, tour } = Astro.props;
const dict = t(locale);
const copy = dict.tourPage.items[tour.id];
const card = dict.tours.items[tour.id];
const path = `tour/${tour.slug}/`;
const pageUrl = absoluteUrl(pagePath(locale, path));
const heroPhoto = getPhoto(tour.galleryKeys[0] ?? tour.image);
const otherTours = TOURS.filter((other) => other.id !== tour.id);
const operatorId = `${absoluteUrl(localeHref('it'))}#operator`;

// Same transform BaseHead runs for og:image — the asset pipeline dedupes it.
const jsonImage = heroPhoto ? await getImage({ src: heroPhoto, format: 'jpeg', width: 1200 }) : null;

const facts = [
  { k: dict.tourPage.factsDuration, v: dict.tours.hours(tour.durationHours) },
  { k: dict.tourPage.factsGroup, v: dict.tourPage.groupValue(tour.minPax, tour.maxGroup) },
  { k: dict.tourPage.factsLanguages, v: dict.tourPage.languagesValue },
  {
    k: dict.tourPage.factsPrice,
    v: `${tour.priceIsFrom ? `${dict.tours.from} ` : ''}R$ ${tour.priceBRL} ${dict.tours.perPerson}`,
  },
];

const crumbs = [
  { label: dict.nav.home, href: pagePath(locale) },
  { label: dict.tourPage.breadcrumbTours, href: localeHref(locale, '#tour') },
  { label: card.name },
];

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TouristTrip',
      name: card.name,
      description: copy.metaDescription,
      url: pageUrl,
      ...(jsonImage && { image: absoluteUrl(jsonImage.src) }),
      provider: {
        '@type': ['TourOperator', 'LocalBusiness'],
        '@id': operatorId,
        name: SITE.name,
        url: absoluteUrl(localeHref('it')),
        sameAs: [SITE.instagram, ...Object.values(tour.otaLinks).filter(Boolean)],
      },
      inLanguage: ['it', 'en', 'pt'],
      itinerary: {
        '@type': 'Place',
        name: tour.meetingPoint,
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Rio de Janeiro',
          addressCountry: 'BR',
        },
      },
      offers: {
        '@type': 'Offer',
        price: tour.priceBRL,
        priceCurrency: 'BRL',
        availability: 'https://schema.org/InStock',
        url: pageUrl,
        ...(tour.priceIsFrom && {
          priceSpecification: {
            '@type': 'PriceSpecification',
            minPrice: tour.priceBRL,
            priceCurrency: 'BRL',
          },
        }),
      },
      subjectOf: {
        '@type': 'CreativeWork',
        abstract: `Duration ${tour.isoDuration}, max ${tour.maxGroup} participants`,
      },
    },
  ],
};
---

<Base
  locale={locale}
  path={path}
  title={copy.metaTitle}
  description={copy.metaDescription}
  ogImage={heroPhoto ?? undefined}
  ogImageAlt={card.name}
>
  <JsonLdScript slot="head" graph={graph} />

  <div class="bg-ink text-paper">
    <div class="mx-auto w-full max-w-6xl px-5 pt-[calc(var(--nav-h)+1.25rem)] pb-4 md:px-10">
      <Breadcrumbs locale={locale} items={crumbs} />
    </div>
  </div>

  <header class="relative bg-ink text-paper">
    {
      heroPhoto ? (
        <Picture
          src={heroPhoto}
          formats={['avif', 'webp']}
          widths={[768, 1200, 1920]}
          sizes="100vw"
          alt={card.name}
          class="h-[48svh] w-full object-cover md:h-[58svh]"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      ) : (
        <div
          class="h-[48svh] w-full md:h-[58svh]"
          style="background: linear-gradient(145deg, var(--color-azzurro) 0%, var(--color-notturno) 100%)"
          role="presentation"
        />
      )
    }
    <div
      class="absolute inset-0 bg-gradient-to-t from-ink via-ink/25 to-ink/25"
      aria-hidden="true"
    >
    </div>
    <div class="absolute inset-x-0 bottom-0 px-5 pb-8 md:px-10 md:pb-10">
      <div class="mx-auto w-full max-w-6xl">
        <p class="eyebrow text-ouro" data-scramble>{copy.kicker}</p>
        <h1
          class="font-display mt-2 max-w-[18ch] text-4xl leading-[1.05] font-bold text-balance md:text-6xl"
          data-reveal-heading
        >
          {card.name}
        </h1>
      </div>
    </div>
  </header>

  <section class="border-b border-paper/10 bg-ink text-paper">
    <dl
      class="mx-auto grid w-full max-w-6xl grid-cols-2 gap-x-8 gap-y-5 px-5 py-6 md:grid-cols-4 md:px-10 md:py-7"
    >
      {
        facts.map((f) => (
          <div>
            <dt class="eyebrow text-paper/55">{f.k}</dt>
            <dd class="mt-1.5 font-mono text-sm tabular-nums">{f.v}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <main id="main">
    <section class="bg-paper text-ink">
      <div
        class="mx-auto grid max-w-6xl gap-10 px-5 py-16 md:grid-cols-[1.2fr_1fr] md:gap-16 md:px-10 md:py-24"
      >
        <div>
          {
            copy.longDesc.map((p) => (
              <p class="mt-5 max-w-prose text-lg leading-relaxed text-ink-soft first:mt-0">{p}</p>
            ))
          }
        </div>
        <aside>
          <h2 class="font-display text-2xl font-bold md:text-3xl">
            {dict.tourPage.highlightsHeading}
          </h2>
          <ul class="mt-5 space-y-3">
            {
              copy.highlights.map((h) => (
                <li class="flex gap-3 leading-relaxed text-ink-soft">
                  <span class="mt-[0.55em] block h-1.5 w-1.5 flex-none rounded-full bg-verde" aria-hidden="true" />
                  {h}
                </li>
              ))
            }
          </ul>
        </aside>
      </div>
    </section>

    <TourGallery
      keys={tour.galleryKeys.slice(1)}
      heading={dict.tourPage.galleryHeading}
      tourName={card.name}
    />

    <section class="bg-paper text-ink">
      <div
        class="mx-auto grid max-w-6xl gap-12 border-t border-ink/15 px-5 py-16 md:grid-cols-2 md:px-10 md:py-20"
      >
        <div>
          <h2 class="font-display text-2xl font-bold md:text-3xl">
            {dict.tourPage.practicalHeading}
          </h2>
          <dl class="mt-6 border-t border-ink/15">
            <div class="grid grid-cols-[8.5rem_1fr] items-baseline gap-4 border-b border-ink/15 py-3.5 md:grid-cols-[10rem_1fr]">
              <dt class="eyebrow text-ink/55">{dict.tourPage.factsMeeting}</dt>
              <dd class="font-display font-semibold">{tour.meetingPoint}</dd>
            </div>
            {
              facts.slice(0, 3).map((f) => (
                <div class="grid grid-cols-[8.5rem_1fr] items-baseline gap-4 border-b border-ink/15 py-3.5 md:grid-cols-[10rem_1fr]">
                  <dt class="eyebrow text-ink/55">{f.k}</dt>
                  <dd class="font-display font-semibold">{f.v}</dd>
                </div>
              ))
            }
          </dl>
          <p class="mt-4 max-w-prose text-sm leading-relaxed text-ink-soft">{copy.meetingNote}</p>

          <h3 class="font-display mt-10 text-xl font-bold">{dict.tourPage.includesHeading}</h3>
          <ul class="mt-4 space-y-2.5">
            {
              copy.includes.map((item) => (
                <li class="flex gap-3 leading-relaxed text-ink-soft">
                  <span class="mt-[0.55em] block h-1.5 w-1.5 flex-none rounded-full bg-ouro" aria-hidden="true" />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h2 class="font-display text-2xl font-bold md:text-3xl">{dict.tourPage.priceHeading}</h2>
          <p class="mt-6 font-mono">
            {tour.priceIsFrom && <span class="text-ink/60">{dict.tours.from} </span>}
            <span class="text-3xl font-medium tabular-nums">R$ {tour.priceBRL}</span>
            <span class="text-ink/60"> {dict.tours.perPerson}</span>
          </p>
          {card.note && <p class="mt-2 font-mono text-xs text-ink/55">{card.note}</p>}
          {
            tour.priceTiers && (
              <table class="mt-6 w-full max-w-sm font-mono text-sm tabular-nums">
                <tbody>
                  {tour.priceTiers.map((tier) => (
                    <tr class="border-t border-ink/15">
                      <td class="py-2.5 pr-4 text-ink/70">
                        {dict.tourPage.tierLabel(tier.minPax, tier.maxPax)}
                      </td>
                      <td class="py-2.5 text-right font-medium">
                        R$ {tier.priceBRL}{' '}
                        <span class="font-normal text-ink/55">{dict.tours.perPerson}</span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )
          }
          <a href="#prenota" class="btn btn-primary mt-8">{dict.tourPage.bookingHeading}</a>
        </div>
      </div>
    </section>

    <TourBooking tour={tour} locale={locale} />

    <section class="bg-paper text-ink">
      <div class="mx-auto max-w-6xl px-5 py-14 md:px-10 md:py-16">
        <h2 class="eyebrow text-ink/55" data-scramble>{dict.tourPage.otherToursHeading}</h2>
        <ul class="mt-6 divide-y divide-ink/15 border-y border-ink/15">
          {
            otherTours.map((other) => (
              <li>
                <a
                  href={pagePath(locale, `tour/${other.slug}/`)}
                  class="group flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 py-5"
                >
                  <span class="font-display text-xl font-bold transition-colors group-hover:text-verde md:text-2xl">
                    {dict.tours.items[other.id].name}
                  </span>
                  <span class="font-mono text-sm text-ink/60 tabular-nums">
                    {dict.tours.hours(other.durationHours)} ·{' '}
                    {other.priceIsFrom ? `${dict.tours.from} ` : ''}R$ {other.priceBRL}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>

  <Footer locale={locale} path={path} />
</Base>
