---
/**
 * The booking section — entirely data-driven from `tour.otaLinks`. While the
 * map is empty it shows the four badges unlinked with the "coming soon" note
 * and an Instagram DM fallback; the moment Leo pastes live listing URLs into
 * tours.ts, the same markup renders real deep-link buttons. No WhatsApp.
 */
import PlatformBadges from '../PlatformBadges.astro';
import { SITE } from '../../data/site';
import { t, type Locale } from '../../i18n';
import type { Tour } from '../../data/tours';

interface Props {
  tour: Tour;
  locale: Locale;
}
const { tour, locale } = Astro.props;
const dict = t(locale);
const hasLive = Object.values(tour.otaLinks).some(Boolean);
---

<section id="prenota" class="bg-ink text-paper">
  <div class="mx-auto max-w-6xl px-5 py-16 md:px-10 md:py-20">
    <h2 class="font-display text-3xl font-bold md:text-4xl" data-reveal-heading>
      {dict.tourPage.bookingHeading}
    </h2>

    {
      hasLive ? (
        <p class="mt-4 max-w-prose text-paper/85">{dict.tourPage.bookingLive}</p>
      ) : (
        <>
          <p class="mt-4 font-mono text-sm tracking-wide text-ouro">{dict.tourPage.bookingSoon}</p>
          <p class="mt-2 max-w-prose leading-relaxed text-paper/75">{dict.tourPage.bookingSoonSub}</p>
        </>
      )
    }

    <PlatformBadges
      links={hasLive ? tour.otaLinks : undefined}
      linkLabel={dict.tourPage.bookingLive}
      class="mt-7"
    />

    {
      !hasLive && (
        <a href={SITE.instagram} class="btn btn-ghost mt-8" rel="noopener" target="_blank">
          {dict.tourPage.instagramDm} · {SITE.instagramHandle}
        </a>
      )
    }
  </div>
</section>
