---
/**
 * The tour deck — every original from the tour's media/ folder beyond the
 * hero, as a stack of cards. Dual-form (DESIGN.md §4): the default styling is
 * a complete, plain photo column; under `.motion-ok` the same nodes become
 * sticky cards that pile up one over the other while deck.ts scrubs the
 * depth cues (covered card settles back and dims) and ticks the live counter.
 * Tolerates missing keys (skipped, never a hole) and renders nothing when
 * the set is empty.
 */
import { Picture } from 'astro:assets';
import { getPhoto } from '../../lib/photos';

interface Props {
  keys: string[];
  heading: string;
  /** Used to build the photos' alt text and the card captions */
  tourName: string;
  /** dict.tourPage.galleryCount — the static total label ("12 fotografie") */
  countLabel: (n: number) => string;
}
const { keys, heading, tourName, countLabel } = Astro.props;
const photos = keys.map((key) => getPhoto(key)).filter((p) => p !== null);
const total = String(photos.length).padStart(2, '0');
---

{
  photos.length > 0 && (
    <section class="bg-paper text-ink" data-deck>
      <div class="mx-auto max-w-6xl px-5 pb-16 md:px-10 md:pb-24">
        <div class="deck-head flex items-baseline justify-between gap-6">
          <h2 class="eyebrow text-ink/55" data-scramble>
            {heading}
          </h2>
          <p class="font-mono text-xs text-ink/65">
            <span class="deck-total">{countLabel(photos.length)}</span>
            <span class="deck-live tabular-nums" aria-hidden="true">
              <span data-deck-current>01</span> / {total}
            </span>
          </p>
        </div>
        <ol class="mt-6 list-none space-y-4" role="list">
          {photos.map((photo, i) => (
            <li class="deck-item" data-deck-item>
              <figure class="deck-card">
                <div class="deck-frame relative overflow-hidden rounded-lg">
                  <Picture
                    src={photo}
                    formats={['avif', 'webp']}
                    widths={[640, 1080, 1600]}
                    sizes="(min-width: 80rem) 72rem, 100vw"
                    alt={`${tourName} — ${heading} ${i + 1}`}
                    class="h-full w-full object-cover"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                  <div class="deck-shade" aria-hidden="true" />
                </div>
                <figcaption class="mt-2 flex items-baseline justify-between font-mono text-xs text-ink/65">
                  <span>{tourName}</span>
                  <span class="tabular-nums">
                    {String(i + 1).padStart(2, '0')} / {total}
                  </span>
                </figcaption>
              </figure>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )
}

<style>
  /* Static form — a complete, plain photo column. */
  .deck-frame {
    aspect-ratio: 4 / 3;
  }
  .deck-live {
    display: none;
  }
  .deck-shade {
    position: absolute;
    inset: 0;
    background: var(--color-ink);
    opacity: 0;
    pointer-events: none;
  }

  /* Motion form — the sticky deck. The li itself sticks (its containing block
     is the whole list), so each card stays pinned under the head while the
     next one rides up and covers it; later siblings paint over earlier ones
     because sticky is positioned. Heights are viewport-derived, never
     image-derived, so lazy loads shift nothing and triggers stay true. */
  :global(.motion-ok) .deck-total {
    display: none;
  }
  :global(.motion-ok) .deck-live {
    display: inline;
  }
  :global(.motion-ok) .deck-head {
    position: sticky;
    top: var(--nav-h);
    z-index: 2;
    background: var(--color-paper);
    padding-block: 0.375rem;
  }
  :global(.motion-ok) .deck-item {
    position: sticky;
    top: calc(var(--nav-h) + 2.75rem);
  }
  :global(.motion-ok) .deck-card {
    background: var(--color-paper);
    transform-origin: center top;
  }
  :global(.motion-ok) .deck-frame {
    aspect-ratio: auto;
    height: calc(100svh - var(--nav-h) - 6.5rem);
  }
</style>
