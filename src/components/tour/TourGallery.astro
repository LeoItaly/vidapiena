---
/**
 * Curated photos of the tour beyond the hero shot. Tolerates missing keys
 * (skipped, never a gradient hole) and renders nothing when the set is empty —
 * galleries grow as Leo curates more originals through `npm run photos`.
 */
import { Picture } from 'astro:assets';
import { getPhoto } from '../../lib/photos';

interface Props {
  keys: string[];
  heading: string;
  /** Used to build the photos' alt text */
  tourName: string;
}
const { keys, heading, tourName } = Astro.props;
const photos = keys.map((key) => getPhoto(key)).filter((p) => p !== null);
---

{
  photos.length > 0 && (
    <section class="bg-paper text-ink">
      <div class="mx-auto max-w-6xl px-5 pb-16 md:px-10 md:pb-24">
        <h2 class="eyebrow text-ink/55" data-scramble>
          {heading}
        </h2>
        <div class="mt-6 grid gap-4 md:grid-cols-[repeat(auto-fit,minmax(16rem,1fr))]" data-stagger>
          {photos.map((photo, i) => (
            <div class="overflow-hidden rounded-lg">
              <Picture
                src={photo}
                formats={['avif', 'webp']}
                widths={[480, 800, 1200]}
                sizes="(min-width: 768px) 30rem, 100vw"
                alt={`${tourName} — ${heading} ${i + 1}`}
                class="gallery-img aspect-[4/3] w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  :global(.motion-ok) .gallery-img {
    transition: transform 0.9s var(--ease-vp-out);
  }
  :global(.motion-ok) div:hover > .gallery-img {
    transform: scale(1.045);
  }
</style>
