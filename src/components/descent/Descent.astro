---
import Backdrop from './Backdrop.astro';
import ZoneSection from './ZoneSection.astro';
import Hud from './Hud.astro';
import { ZONES } from '../../data/zones';
import { t, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

{/* Sits *outside* #descent on purpose: descent.ts maps scroll progress across
    that container's full height, so anything added inside would skew every
    zone band and the altimeter with them. */}
<section class="bg-ink px-5 py-20 text-center md:py-28">
  <p class="eyebrow text-ambra">{dict.descentIntro.kicker}</p>
  <h2 class="font-display mt-4 text-3xl font-bold text-balance md:text-5xl">
    <span class="block">{dict.descentIntro.h2[0]}</span>
    <span class="block text-ambra">{dict.descentIntro.h2[1]}</span>
  </h2>
  <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-paper/80">
    {dict.descentIntro.sub}
  </p>
</section>

<div id="descent" class="relative bg-ink">
  <Backdrop />
  {ZONES.map((zone) => <ZoneSection zone={zone} locale={locale} />)}
</div>
<Hud />
