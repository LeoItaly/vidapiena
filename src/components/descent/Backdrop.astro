---
import { Picture } from 'astro:assets';
import { ZONES } from '../../data/zones';
import { getPhoto } from '../../lib/photos';
---

<!-- Decorative visual layer of the descent. All information it carries is
     duplicated as text + inline figures inside the zone sections. -->
<div class="absolute inset-0" aria-hidden="true" data-backdrop>
  <div class="sticky top-0 h-svh overflow-hidden">
    {
      ZONES.map((zone, i) => {
        const photo = getPhoto(zone.image);
        return (
          <div
            class="backdrop-layer absolute inset-0"
            data-zone-layer={zone.id}
            style={`--grade: var(${zone.gradeVar})`}
          >
            {photo ? (
              <Picture
                src={photo}
                formats={['avif', 'webp']}
                widths={[640, 960, 1440, 2048]}
                sizes="100vw"
                alt=""
                class="backdrop-img h-full w-full object-cover"
                style={`object-position: ${zone.focus}`}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            ) : (
              <div
                class="h-full w-full"
                style={`background: linear-gradient(180deg, color-mix(in oklab, var(${zone.gradeVar}) 45%, var(--color-ink)) 0%, var(--color-ink) 85%)`}
              />
            )}
            <div
              class="absolute inset-0"
              style="background: linear-gradient(180deg, color-mix(in srgb, var(--grade) 14%, transparent) 0%, color-mix(in srgb, var(--color-ink) 38%, transparent) 74%, color-mix(in srgb, var(--color-ink) 90%, transparent) 100%)"
            />
          </div>
        );
      })
    }
  </div>
</div>
