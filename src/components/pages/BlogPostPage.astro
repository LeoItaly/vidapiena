---
import { render, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHero from './PageHero.astro';
import Footer from '../Footer.astro';
import JsonLdScript from '../JsonLdScript.astro';
import { SITE } from '../../data/site';
import { t, pagePath, absoluteUrl, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
  post: CollectionEntry<'blog'>;
}
const { locale, post } = Astro.props;
const dict = t(locale);
const slug = post.id.replace(/^(it|en)\//, '');
const path = `blog/${slug}/`;
const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat(locale === 'it' ? 'it-IT' : 'en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const graph = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString().slice(0, 10),
  inLanguage: locale,
  url: absoluteUrl(pagePath(locale, path)),
  author: {
    '@type': 'Person',
    name: SITE.guide.name,
    sameAs: [SITE.instagram],
  },
};
---

<Base locale={locale} path={path} title={post.data.title} description={post.data.description}>
  <JsonLdScript slot="head" graph={graph} />
  <PageHero kicker={dateFmt.format(post.data.date)} heading={post.data.title} />

  <main id="main">
    <section class="bg-paper text-ink">
      <div class="mx-auto max-w-6xl px-5 py-16 md:px-10 md:py-24">
        <article class="article-body max-w-prose">
          <Content />
        </article>
        <p class="mt-12">
          <a href={pagePath(locale, 'blog/')} class="eyebrow link-sweep text-verde">
            {dict.blog.backToBlog}
          </a>
        </p>
      </div>
    </section>
  </main>

  <Footer locale={locale} path={path} />
</Base>

<style>
  /* Markdown body — modest editorial defaults on paper. */
  .article-body :global(p) {
    margin-top: 1.1em;
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-ink-soft);
  }
  .article-body :global(h2) {
    margin-top: 2em;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
  }
  .article-body :global(h3) {
    margin-top: 1.6em;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin-top: 1.1em;
    padding-left: 1.2em;
    list-style: disc;
    color: var(--color-ink-soft);
  }
  .article-body :global(ol) {
    list-style: decimal;
  }
  .article-body :global(li) {
    margin-top: 0.4em;
    line-height: 1.7;
  }
  .article-body :global(a) {
    color: var(--color-verde);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article-body :global(img) {
    margin-top: 1.5em;
    border-radius: 0.5rem;
  }
  .article-body :global(blockquote) {
    margin-top: 1.5em;
    border-left: 3px solid var(--color-ouro);
    padding-left: 1em;
    font-style: italic;
  }
</style>
