---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import ogBase from '../assets/og/og-base.jpg';
import { getHeroPosters, POSTER_MEDIA } from '../lib/posters';
import displayFontUrl from '@fontsource-variable/bricolage-grotesque/files/bricolage-grotesque-latin-wght-normal.woff2?url';
import {
  t,
  pagePath,
  absoluteUrl,
  ogLocale,
  LOCALES,
  DEFAULT_LOCALE,
  type Locale,
} from '../i18n';

interface Props {
  locale: Locale;
  /** Locale-neutral page tail ('' = home) — drives canonical, hreflang, og:url. */
  path?: string;
  title?: string;
  description?: string;
  /** Social-card override (tour pages pass their hero photo). */
  ogImage?: ImageMetadata;
  ogImageAlt?: string;
  /** Landing only: the hero posters are its LCP and must win the preload race. */
  preloadHeroPosters?: boolean;
}
const { locale, path = '', ogImage, ogImageAlt, preloadHeroPosters = false } = Astro.props;
const dict = t(locale);
const title = Astro.props.title ?? dict.meta.title;
const description = Astro.props.description ?? dict.meta.description;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonical = absoluteUrl(pagePath(locale, path));

const ogSource = ogImage ?? ogBase;
const og = await getImage({ src: ogSource, format: 'jpeg', width: 1200 });
const ogHeight = ogImage ? Math.round((1200 * ogImage.height) / ogImage.width) : 630;
const ogAlt = ogImageAlt ?? dict.meta.ogAlt;
const posters = preloadHeroPosters ? await getHeroPosters() : null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{LOCALES.map((l) => <link rel="alternate" hreflang={l} href={absoluteUrl(pagePath(l, path))} />)}
<link rel="alternate" hreflang="x-default" href={absoluteUrl(pagePath(DEFAULT_LOCALE, path))} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="Vidapiena" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={absoluteUrl(og.src)} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content={String(ogHeight)} />
<meta property="og:image:alt" content={ogAlt} />
<meta property="og:locale" content={ogLocale(locale)} />
{
  LOCALES.filter((l) => l !== locale).map((l) => (
    <meta property="og:locale:alternate" content={ogLocale(l)} />
  ))
}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteUrl(og.src)} />

<meta name="theme-color" content="#10150f" />
<link rel="icon" href={`${base}/favicon.png`} sizes="32x32" />
<link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />

{
  posters && (
    <>
      <link
        rel="preload"
        as="image"
        href={posters.landscape.src}
        media={POSTER_MEDIA.landscape}
        fetchpriority="high"
      />
      <link
        rel="preload"
        as="image"
        href={posters.portrait.src}
        media={POSTER_MEDIA.portrait}
        fetchpriority="high"
      />
    </>
  )
}
<!-- Only the display face is preloaded — it renders the headline; the body face
     swaps in without competing with the poster (the LCP element) for 4G bandwidth. -->
<link rel="preload" as="font" type="font/woff2" href={displayFontUrl} crossorigin />

<link rel="sitemap" href={`${base}/sitemap-index.xml`} />
