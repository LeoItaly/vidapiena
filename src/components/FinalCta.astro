---
/**
 * The minimal close — one heading, one line, two exits (tours, Instagram).
 * The sea-level/altitude framing retired with the descent.
 */
import { SITE } from '../data/site';
import { t, localeHref, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

{/* Guanabara dusk as a dip, not a block: the gradient enters and exits on ink,
    welding this band to its ink neighbors — no seam either side. */}
<section
  class="text-paper"
  style="background: linear-gradient(180deg, var(--color-ink) 0%, var(--color-notturno) 46%, var(--color-ink) 94%)"
>
  <div class="mx-auto max-w-4xl px-5 py-20 text-center md:px-10 md:py-28">
    <h2 class="font-display text-4xl font-bold text-balance md:text-6xl" data-reveal-heading>
      {dict.finalCta.heading}
    </h2>
    <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-paper/85 md:text-lg">
      {dict.finalCta.sub}
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a href={localeHref(locale, '#tour')} class="btn btn-primary">{dict.finalCta.ctaTours}</a>
      <a href={SITE.instagram} class="btn btn-ghost" rel="noopener" target="_blank">
        {dict.finalCta.instagramLabel} · {SITE.instagramHandle}
      </a>
    </div>
  </div>
</section>
