---
import LangSwitch from './LangSwitch.astro';
import { SITE } from '../data/site';
import { t, pagePath, localeHref, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  /** Locale-neutral tail of the current page — forwarded to LangSwitch. */
  path?: string;
}
const { locale, path = '' } = Astro.props;
const dict = t(locale);
const year = new Date().getFullYear();

/* The full site map lives here too — it is the drawer's no-JS fallback and
   gives crawlers a plain-anchor path to every page. */
const links = [
  { label: dict.nav.home, href: pagePath(locale) },
  { label: dict.nav.tours, href: localeHref(locale, '#tour') },
  { label: dict.nav.blog, href: pagePath(locale, 'blog/') },
  { label: dict.nav.guide, href: pagePath(locale, 'la-guida/') },
  { label: dict.nav.contact, href: pagePath(locale, 'contatti/') },
];
---

<footer class="border-t border-paper/10 bg-ink text-paper">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-8 px-5 py-10 md:flex-row md:items-start md:justify-between md:px-10"
  >
    <div>
      <p class="font-display text-sm font-bold tracking-[0.28em] uppercase">Vidapiena</p>
      <p class="mt-2 text-sm text-paper/70">{dict.footer.line}</p>
    </div>

    <nav aria-label={dict.nav.footerLabel}>
      <ul class="flex max-w-xs flex-wrap gap-x-6 gap-y-2.5 font-mono text-xs tracking-[0.18em] uppercase">
        {
          links.map((l) => (
            <li>
              <a href={l.href} class="link-sweep opacity-80 transition-opacity hover:opacity-100">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-8">
      <a
        href={SITE.instagram}
        class="link-sweep font-mono text-xs tracking-[0.18em] uppercase opacity-80 transition-opacity hover:opacity-100"
        rel="noopener"
        target="_blank"
        data-scramble-hover
      >
        Instagram
      </a>
      <LangSwitch locale={locale} path={path} />
    </div>
  </div>
  <p class="px-5 pb-6 text-center font-mono text-[0.65rem] text-paper/40 md:px-10">
    © {year} Vidapiena
  </p>
</footer>
