---
import { SITE } from '../data/site';
import { TOURS } from '../data/tours';
import { t, localeHref, pagePath, absoluteUrl, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);

/*
 * One @graph, all values imported from src/data/ — the same modules that render
 * the visible UI, so the schema can never drift from the page.
 * sameAs gains the 4 OTA listing URLs as soon as tours.ts has them (M6 gate).
 */
const otaSameAs = TOURS.flatMap((tour) => Object.values(tour.otaLinks)).filter(Boolean);

const operatorId = `${absoluteUrl(localeHref('it'))}#operator`;
/* The official circular badge, served from public/ (regenerated by
   scripts/make-icons.mjs from visual-references/new-logo.jpeg). */
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const logoUrl = absoluteUrl(`${base}/icon-512.png`);

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['TourOperator', 'LocalBusiness'],
      '@id': operatorId,
      name: SITE.name,
      description: dict.meta.description,
      url: absoluteUrl(localeHref('it')),
      logo: logoUrl,
      image: logoUrl,
      areaServed: { '@type': 'City', name: 'Rio de Janeiro' },
      knowsLanguage: ['it', 'en', 'pt'],
      founder: { '@type': 'Person', name: SITE.guide.name },
      sameAs: [SITE.instagram, ...otaSameAs],
    },
    {
      '@type': 'WebSite',
      name: SITE.name,
      url: absoluteUrl(localeHref('it')),
      inLanguage: locale,
    },
    {
      /* Summary list only — the full TouristTrip (offers, itinerary, image)
         lives on each detail page. Google's recommended list→detail split. */
      '@type': 'ItemList',
      name: dict.tours.heading,
      itemListElement: TOURS.map((tour, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'TouristTrip',
          name: dict.tours.items[tour.id].name,
          url: absoluteUrl(pagePath(locale, `tour/${tour.slug}/`)),
        },
      })),
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(graph)} is:inline />
