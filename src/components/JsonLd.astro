---
import { SITE } from '../data/site';
import { TOURS } from '../data/tours';
import { t, localeHref, absoluteUrl, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
const pageUrl = absoluteUrl(localeHref(locale));

/*
 * One @graph, all values imported from src/data/ — the same modules that render
 * the visible UI, so the schema can never drift from the page.
 * sameAs gains the 4 OTA listing URLs as soon as tours.ts has them (M6 gate).
 */
const otaSameAs = TOURS.flatMap((tour) => Object.values(tour.otaLinks)).filter(Boolean);

const operatorId = `${absoluteUrl(localeHref('it'))}#operator`;

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['TourOperator', 'LocalBusiness'],
      '@id': operatorId,
      name: SITE.name,
      description: dict.meta.description,
      url: absoluteUrl(localeHref('it')),
      areaServed: { '@type': 'City', name: 'Rio de Janeiro' },
      knowsLanguage: ['it', 'en', 'pt'],
      founder: { '@type': 'Person', name: SITE.guide.name },
      sameAs: [SITE.instagram, ...otaSameAs],
    },
    {
      '@type': 'WebSite',
      name: SITE.name,
      url: absoluteUrl(localeHref('it')),
      inLanguage: locale,
    },
    {
      '@type': 'ItemList',
      name: dict.tours.heading,
      itemListElement: TOURS.map((tour, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'TouristTrip',
          name: dict.tours.items[tour.id].name,
          description: dict.tours.items[tour.id].hook,
          url: `${pageUrl}#tour`,
          provider: { '@id': operatorId },
          inLanguage: ['it', 'en', 'pt'],
          itinerary: {
            '@type': 'Place',
            name: tour.meetingPoint,
            address: { '@type': 'PostalAddress', addressLocality: 'Rio de Janeiro', addressCountry: 'BR' },
          },
          offers: {
            '@type': 'Offer',
            price: tour.priceBRL,
            priceCurrency: 'BRL',
            availability: 'https://schema.org/InStock',
            ...(tour.priceIsFrom && { priceSpecification: {
              '@type': 'PriceSpecification',
              minPrice: tour.priceBRL,
              priceCurrency: 'BRL',
            }}),
          },
          subjectOf: { '@type': 'CreativeWork', abstract: `Duration ${tour.isoDuration}, max ${tour.maxGroup} participants` },
        },
      })),
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(graph)} is:inline />
