---
import { Picture } from 'astro:assets';
import RouteMark from './RouteMark.astro';
import SprayStroke from './SprayStroke.astro';
import { getPhoto } from '../lib/photos';
import { t, pagePath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
const photo = getPhoto('guide-francesco');
---

<section id="guida" class="relative bg-paper text-ink">
  <RouteMark alt={120} accent="verde-scuro" tone="light" />
  <div class="mx-auto grid max-w-6xl gap-10 px-5 pt-12 pb-20 md:grid-cols-[1.15fr_1fr] md:gap-16 md:px-10 md:pt-14 md:pb-28">
    <div>
      <h2
        class="font-display text-4xl font-bold md:text-5xl"
        style="--stroke: var(--color-verde)"
        data-reveal-heading
      >
        {dict.guide.heading}
        <SprayStroke />
      </h2>
      <p class="mt-6 max-w-prose text-lg leading-relaxed text-ink-soft">{dict.guide.intro}</p>

      <dl class="mt-10 border-t border-ink/15">
        {
          dict.guide.stats.map((s, i) => (
            <div class="grid grid-cols-[9rem_1fr] items-baseline gap-4 border-b border-ink/15 py-3.5 md:grid-cols-[11rem_1fr]">
              <dt class="eyebrow text-ink/55">{s.k}</dt>
              <dd class="font-display text-lg font-semibold md:text-xl">
                {i === 0 && <span class="stat-dot" aria-hidden="true" />}
                {s.v}
              </dd>
            </div>
          ))
        }
      </dl>

      <a
        href={pagePath(locale, 'la-guida/')}
        class="link-sweep eyebrow mt-8 inline-block text-verde-scuro"
      >
        {dict.guide.aboutCta}
      </a>
    </div>

    {/* Clipping frame: the portrait is over-scaled and drifts inside it, so the
        parallax never exposes an edge. On md it rises across the morro seam
        into the dark band above — the person straddles the boundary. */}
    <div class="order-first overflow-hidden rounded-lg md:order-none md:relative md:z-10 md:-mt-24">
      {
        photo ? (
          <Picture
            src={photo}
            formats={['avif', 'webp']}
            widths={[480, 800, 1200]}
            sizes="(min-width: 768px) 26rem, 100vw"
            alt={dict.guide.photoAlt}
            class="aspect-[4/5] w-full rounded-lg object-cover"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div
            class="aspect-[4/5] w-full rounded-lg"
            style="background: linear-gradient(160deg, var(--color-verde) 0%, var(--color-notturno) 90%)"
            role="presentation"
          />
        )
      }
    </div>
  </div>
</section>

<style>
  /* The intro's rosso signal device, reused exactly once in the page body:
     it points at Italy (the first stat — the native-Italian guide). */
  .stat-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    margin-right: 0.55rem;
    border-radius: 999px;
    background: var(--color-rosso);
    vertical-align: 0.18em;
  }
</style>
