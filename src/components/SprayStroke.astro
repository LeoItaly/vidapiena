---
/**
 * The one graffiti device of the site: a hand-sprayed underline stroke.
 * Colored via `--stroke` custom property (defaults to the Brazilian gold).
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  class={`spray-stroke ${className}`}
  viewBox="0 0 220 14"
  fill="none"
  preserveAspectRatio="none"
  aria-hidden="true"
  data-spray
>
  <path
    d="M4 9.5C36 5.5 74 4 108 5.2c30 1 62 3.3 84 2.1M12 12c22-1.6 41-2.4 58-2.2"
    stroke="var(--stroke, var(--color-ouro))"
    stroke-width="4.5"
    stroke-linecap="round"
    opacity="0.9"></path>
</svg>

<style>
  .spray-stroke {
    display: block;
    width: min(14ch, 100%);
    height: 0.42em;
    margin-top: 0.12em;
  }
</style>
