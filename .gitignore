# Dependencies & builds (for when coding starts)
node_modules/
dist/
build/
.next/
.astro/
.svelte-kit/
.output/
.vercel/
.netlify/

# Env & secrets — never commit
.env
.env.*
!.env.example

# Local tooling
.claude/
*.local

# Build-time Instagram import — ephemeral, regenerated every build (scripts/fetch-instagram.mjs).
# Behold is the source of truth; committing these would only add daily binary churn.
src/assets/instagram/*.jpg
src/data/instagram-feed.json

# OS junk
Thumbs.db
desktop.ini
.DS_Store

# Logs
*.log
npm-debug.log*
